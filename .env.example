# Firebase public web config (safe to expose — security is enforced by
# Firestore rules, not by hiding these values).
VITE_FIREBASE_API_KEY=
VITE_GOOGLE_CLIENT_ID=
# In PRODUCTION set this to your app's own domain (e.g. `1600.now`). The
# nginx config in this repo proxies `/__/auth/*` to firebaseapp.com, which
# makes Google sign-in same-origin and avoids the `auth/missing-initial-state`
# error caused by storage-partitioned browsers.
VITE_FIREBASE_AUTH_DOMAIN=
# Optional Firebase Hosting domain for email verification/password reset links.
VITE_FIREBASE_AUTH_LINK_DOMAIN=
# Used only when running `vite dev` on localhost — keep this as the
# `<project>.firebaseapp.com` value since localhost can't proxy to Firebase.
VITE_FIREBASE_AUTH_DOMAIN_LOCAL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_USE_FIREBASE_EMULATORS=false
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Copy from Firebase
# console → Project Settings → Your apps → SDK setup. If unset, analytics
# is disabled silently (no events logged).
VITE_FIREBASE_MEASUREMENT_ID=
# Desmos graphing-calculator API key. This is a PUBLIC, client-visible key
# (embedded in the script URL in the browser). If unset, the app falls back to
# Desmos's shared demo key, which is subject to rate-limiting and can be
# revoked at any time. For production, request your own key from Desmos
# (https://www.desmos.com/api) tied to your domain.
VITE_DESMOS_API_KEY=
# Firebase App Check reCAPTCHA v3 site key. When set (and App Check is enforced
# in the Firebase console under Project Settings → App Check), only tokens from
# the real app can write to Firestore, blocking scripted abuse of the reports
# collection. Leave unset to disable App Check (no behavior change).
VITE_RECAPTCHA_SITE_KEY=
