{
  "hosting": {
    "public": "dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/free-sat-practice",
        "destination": "/free-sat-prep",
        "type": 301
      },
      {
        "source": "/digital-sat-prep",
        "destination": "/free-sat-prep",
        "type": 301
      },
      {
        "source": "/online-sat-prep",
        "destination": "/free-sat-prep",
        "type": 301
      },
      {
        "source": "/best-sat-prep",
        "destination": "/free-sat-prep",
        "type": 301
      },
      {
        "source": "/sat-study-guide",
        "destination": "/free-sat-prep",
        "type": 301
      },
      {
        "source": "/sat-practice-test",
        "destination": "/modules",
        "type": 301
      },
      {
        "source": "/sat-practice-questions",
        "destination": "/bank",
        "type": 301
      },
      {
        "source": "/sat-question-bank-free",
        "destination": "/bank",
        "type": 301
      },
      {
        "source": "/sat-writing-practice",
        "destination": "/sat-reading-practice",
        "type": 301
      },
      {
        "source": "/browse",
        "destination": "/bank",
        "type": 301
      },
      {
        "regex": "^/is-a-(?P<score>(?:[4-9][0-9]0|1[0-5][0-9]0|1600))-a-good-sat-score$",
        "destination": "/sat-score/:score",
        "type": 301
      },
      {
        "source": "/study-plan-lab",
        "destination": "/sat-study-plan-generator",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/@(login|signup|verify-email|analysis|test-results|my-practice-sets)",
        "destination": "/spa-shell.html"
      },
      {
        "source": "/profile{,/**}",
        "destination": "/spa-shell.html"
      },
      {
        "source": "/practice-tests{,/**}",
        "destination": "/spa-shell.html"
      },
      {
        "source": "/modules/**",
        "destination": "/spa-shell.html"
      },
      {
        "source": "/bank/**",
        "destination": "/spa-shell.html"
      },
      {
        "source": "/hard/**",
        "destination": "/spa-shell.html"
      },
      {
        "source": "/admin{,/**}",
        "destination": "/spa-shell.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=63072000; includeSubDomains; preload"
          },
          {
            "key": "Permissions-Policy",
            "value": "geolocation=(), microphone=(), camera=(), payment=()"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://www.desmos.com https://apis.google.com https://www.gstatic.com https://www.gstatic.com/recaptcha/ https://www.google.com/recaptcha/ https://www.googletagmanager.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://*.google.com https://www.google.com/recaptcha/ https://apis.google.com https://www.gstatic.com https://*.firebaseio.com https://*.firebaseapp.com https://www.googletagmanager.com https://*.google-analytics.com https://region1.google-analytics.com https://*.analytics.google.com; frame-src 'self' https://now-483609.firebaseapp.com https://*.firebaseapp.com https://accounts.google.com https://www.google.com/recaptcha/ https://recaptcha.google.com/recaptcha/ https://www.desmos.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/@(login|signup|verify-email|analysis|test-results|my-practice-sets)",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, follow"
          }
        ]
      },
      {
        "source": "/@(profile|practice-tests|admin){,/**}",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, follow"
          }
        ]
      },
      {
        "source": "/@(modules|bank|hard)/**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, follow"
          }
        ]
      },
      {
        "source": "/@(spa-shell.html|404.html)",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          }
        ]
      },
      {
        "source": "/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/optimized/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      },
      {
        "source": "/images/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      },
      {
        "source": "/reference-sheet/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      },
      {
        "source": "/favicon.ico",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      },
      {
        "source": "/og-image.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      },
      {
        "source": "/logo_b.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=604800"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/generated/sat-images/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/generated/bank-question-shards/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/generated/bank-search/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "auth": {
      "host": "127.0.0.1",
      "port": 9099
    },
    "firestore": {
      "host": "127.0.0.1",
      "port": 8089
    },
    "ui": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 4000
    },
    "singleProjectMode": true
  }
}
