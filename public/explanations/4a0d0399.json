  "steps": [
    {
      "title": "Use the y-intercept",
      "content": "The $y$-intercept $(0,-285)$ means $f(0)=-285$. Substitute $x=0$ into $f(x)=a^x+b$:\n$$\na^0+b=-285\n$$"
    },
    {
      "title": "Find the constant",
      "content": "Since $a^0=1$ for a nonzero base,\n$$\n1+b=-285\n$$\n$$\nb=-286\n$$\nThe answer is <strong>-286</strong>."
    }
  ]
}
