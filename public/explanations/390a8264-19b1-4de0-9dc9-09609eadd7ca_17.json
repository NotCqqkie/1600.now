  "steps": [
    {
      "title": "Use the y-intercept to find b",
      "content": "At the $y$-intercept, $x = 0$ and $y = -17$:<br/>$$a^0 + b = -17$$<br/>$$1 + b = -17$$<br/>$$b = -18$$"
    },
    {
      "title": "Find a and calculate a - b",
      "content": "Using the point $(2, 31)$:<br/>$$a^2 + b = 31$$<br/>Substitute $b = -18$:<br/>$$a^2 - 18 = 31$$<br/>$$a^2 = 49$$<br/>Since $a \\gt  0$: $a = 7$<br/><br/>Therefore:<br/>$$a - b = 7 - (-18) = 25$$"
    }
  ]
}