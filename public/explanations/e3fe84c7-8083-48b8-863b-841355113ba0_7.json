  "correctAnswer": "C",
  "section": "Math",
  "steps": [
    {
      "title": "Set up",
      "content": "Start with $r = \\sqrt{9w - 5}$. Square both sides to remove the radical: $r^2 = 9w - 5$."
    },
    {
      "title": "Solve",
      "content": "Add 5: $r^2 + 5 = 9w$. Divide by 9: $$w = \\frac{r^2 + 5}{9}$$"
    },
    {
      "title": "Answer",
      "content": "<strong>C</strong> is correct."
    }
  ]
}
