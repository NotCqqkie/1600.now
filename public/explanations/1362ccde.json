  "steps": [
    {
      "title": "Substitute the expression",
      "content": "Use $y=4x+1$ in the second equation.<br/>$$4y=15x-8$$<br/>$$4(4x+1)=15x-8$$"
    },
    {
      "title": "Solve the system",
      "content": "Expand and isolate $x$.<br/>$$16x+4=15x-8$$<br/>$$x=-12$$<br/>Then find $y$.<br/>$$y=4(-12)+1=-47$$"
    },
    {
      "title": "Calculator shortcut",
      "content": "Graph the two equations, read the intersection $(-12,-47)$, and subtract.<br/>$$x-y=-12-(-47)=35$$<br/>The answer is <strong>35</strong>.",
      "desmosExpressions": [
        "y=4x+1",
        "4y=15x-8"
      ]
    }
  ]
