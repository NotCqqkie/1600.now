  "steps": [
    {
      "title": "Complete the square for x and y",
      "content": "$x^2 - 6x + y^2 - 4y - 51 = 0$ becomes $(x-3)^2 - 9 + (y-2)^2 - 4 - 51 = 0$, so $(x-3)^2 + (y-2)^2 = 64$."
    },
    {
      "title": "Identify the center and radius",
      "content": "Center $(3, 2)$, radius $r = \\sqrt{64} = 8$."
    },
    {
      "title": "Compute the requested value",
      "content": "Square side $= 2r = 16$, so perimeter $= 4 \\times 16 = 64$. That matches choice <strong>C</strong> — <strong>C</strong> is correct.",
      "desmosExpressions": [
        "x^2 - 6x + y^2 - 4y - 51 = 0",
        "(x-3)^2 + (y-2)^2 = 64"
      ]
    }
