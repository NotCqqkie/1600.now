  "section": "Math",
  "steps": [
    {
      "title": "Factor the quadratic",
      "content": "Find two factors of $5x^2-37x-24$:<br/>$$5x^2-37x-24=(5x+3)(x-8)$$"
    },
    {
      "title": "Set each factor equal to zero",
      "content": "$$(5x+3)(x-8)=0$$<br/>So either $5x+3=0$ or $x-8=0$. The solutions are:<br/>$$x=-\\frac{3}{5}\\quad\\text{or}\\quad x=8$$"
    },
    {
      "title": "Pick the positive solution",
      "content": "The positive solution is $8$."
    },
    {
      "title": "Check the positive solution",
      "content": "Substitute $x=8$: $$5(8)^2-37(8)-24=320-296-24=0.$$ So $8$ is a valid solution."
    },
    {
      "title": "Answer",
      "content": "$8$ matches <strong>Choice C &mdash; $8$</strong>, so <strong>C</strong> is correct."
    }
  ]
}
