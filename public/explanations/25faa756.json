  "steps": [
    {
      "title": "Express a in terms of b",
      "content": "Since $a$ is 40% greater than $b$:<br/>$$a = b + 0.40b = 1.40b$$"
    },
    {
      "title": "Express c in terms of a",
      "content": "Since $c$ is 40% less than $a$:<br/>$$c = a - 0.40a = 0.60a$$"
    },
    {
      "title": "Substitute to find the multiple",
      "content": "Substitute $a = 1.40b$ into $c = 0.60a$:<br/>$$c = 0.60(1.40b) = 0.84b$$<br/>Therefore, $c$ is <strong>0.84</strong> times $b$."
    }
  ]
