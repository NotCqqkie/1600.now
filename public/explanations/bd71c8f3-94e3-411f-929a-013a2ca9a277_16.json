  "section": "Math",
  "steps": [
    {
      "title": "Expand the right side",
      "content": "Distribute 7: $$7(w - 0.001) = 7w - 0.007$$ The equation becomes $$0.7w - 0.57 = 7w - 0.007$$"
    },
    {
      "title": "Collect like terms",
      "content": "Move all $w$ terms to the left and constants to the right: $$0.7w - 7w = -0.007 + 0.57$$ $$-6.3w = 0.563$$"
    },
    {
      "title": "Solve for w",
      "content": "Divide both sides by $-6.3$: $$w = \\frac{0.563}{-6.3} \\approx -0.089$$"
    }
  ]
}