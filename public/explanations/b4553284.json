    {
      "title": "Solve for x",
      "content": "Divide both sides of $2x = 12$ by 2.<br/>$$x = \\frac{12}{2} = 6$$"
    },
    {
      "title": "Calculate 9x",
      "content": "Substitute $x = 6$ into $9x$.<br/>$$9x = 9 \\cdot 6 = 54$$"
    }
