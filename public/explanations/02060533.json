  "steps": [
    {
      "title": "Convert to values of f",
      "content": "Since $g(x)=\\frac{f(x)}{x+3}$, multiply by $x+3$.<br/>$$f(x)=g(x)(x+3)$$<br/>Using $x=-9$ and $x=27$:<br/>$$f(-9)=0(-9+3)=0$$<br/>$$f(27)=6(27+3)=180$$"
    },
    {
      "title": "Find the linear function",
      "content": "The slope of $f$ through $(-9{,}0)$ and $(27{,}180)$ is<br/>$$\\frac{180-0}{27-(-9)}=\\frac{180}{36}=5$$<br/>Using $(-9{,}0)$:<br/>$$f(x)=5(x+9)=5x+45$$"
    },
    {
      "title": "Read the intercept",
      "content": "The $y$-intercept occurs when $x=0$.<br/>$$f(0)=45$$<br/>So the intercept is $(0{,}45)$. The answer is <strong>A</strong>."
    }
  ]
}
