  "section": "Math",
  "steps": [
    {
      "title": "Set up",
      "content": "Group the like terms in $4yz^3 + 3yz^3 + 5yz$: the $yz^3$ terms can be combined; $5yz$ has no like term."
    },
    {
      "title": "Solve",
      "content": "$4yz^3 + 3yz^3 = 7yz^3$, so the expression simplifies to $7yz^3 + 5yz$."
    },
    {
      "title": "Answer",
      "content": "<strong>A</strong> is correct."
    }
  ]
}
