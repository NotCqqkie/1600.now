  "steps": [
    {
      "title": "Set up",
      "content": "The first 25 people cost $28 each: $25 \\times 28 = 700$. Each person beyond 25 costs $17, giving $(n - 25)$ extra people when $n \\geq 25$."
    },
    {
      "title": "Solve",
      "content": "$$f(n) = 700 + 17(n-25) = 700 + 17n - 425 = 17n + 275$$"
    },
    {
      "title": "Answer",
      "content": "<strong>A</strong> is correct.",
      "desmosExpressions": [
        "y = 17x + 275 \\{x \\geq 25\\}"
      ]
    }
  ]
}