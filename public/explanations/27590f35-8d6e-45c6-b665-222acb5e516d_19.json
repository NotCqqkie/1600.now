  "steps": [
    {
      "title": "Set up",
      "content": "The sphere is inscribed in the cube, so it touches each face at its center. The radius equals half the edge length: $r = 82 \\div 2 = 41$ inches."
    },
    {
      "title": "Solve",
      "content": "Cube volume: $$82^3=551{,}368\\text{ in}^3.$$ Sphere volume: $$\\frac{4}{3}\\pi(41)^3=\\frac{4}{3}\\pi(68{,}921)\\approx288{,}696\\text{ in}^3.$$ Remaining volume: $$551{,}368-288{,}696=262{,}672\\text{ in}^3.$$"
    },
    {
      "title": "Answer",
      "content": "<strong>A</strong> is correct."
    }
  ]
}
