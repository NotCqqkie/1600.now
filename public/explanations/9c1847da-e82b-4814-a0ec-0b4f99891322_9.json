  "steps": [
    {
      "title": "Set up",
      "content": "Distribute the minus sign across the second group: $$(6x^3 - 6x + 4) - (7x^2 + 7x - 2) = 6x^3 - 6x + 4 - 7x^2 - 7x + 2$$"
    },
    {
      "title": "Solve",
      "content": "Combine like terms: $$6x^3 - 7x^2 + (-6x - 7x) + (4 + 2) = 6x^3 - 7x^2 - 13x + 6$$"
    },
    {
      "title": "Answer",
      "content": "<strong>C</strong> is correct."
    }
  ]
}
