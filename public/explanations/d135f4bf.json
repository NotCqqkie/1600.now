    {
      "title": "Translate the graph up 6 units",
      "content": "Translating the graph of $y=f(x)$ up 6 units adds 6 to the output: $$g(x)=f(x)+6$$."
    },
    {
      "title": "Evaluate f(0)",
      "content": "Substitute $x=0$ into $f(x)=(x-5)(x-3)(x+5)$:<br/>$$f(0)=(0-5)(0-3)(0+5)=(-5)(-3)(5)$$<br/>Compute step by step:<br/>$$(-5)(-3)=15$$<br/>$$15\\times5=75$$<br/>Thus $$f(0)=75$$."
    },
    {
      "title": "Compute g(0) and select answer",
      "content": "Use the translation: $$g(0)=f(0)+6=75+6=81$$.<br/>The answer is <strong>81</strong>."
    }
  ]
}