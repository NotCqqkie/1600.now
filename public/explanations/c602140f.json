  "steps": [
    {
      "title": "Expand the first product",
      "content": "Use distribution on the first product:<br/>$$(x-9y)(2x-5y)=2x^2-5xy-18xy+45y^2$$<br/>$$2x^2-23xy+45y^2$$"
    },
    {
      "title": "Expand the second product",
      "content": "Distribute $-8y$ through the second factor:<br/>$$-8y(-2x+5y)=16xy-40y^2$$"
    },
    {
      "title": "Combine like terms",
      "content": "Add the expanded parts:<br/>$$2x^2-23xy+45y^2+16xy-40y^2$$<br/>$$2x^2-7xy+5y^2$$<br/>The answer is <strong>B</strong>."
    }
  ]
}
