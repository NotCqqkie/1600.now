  "steps": [
    {
      "title": "Substitute the value x = 2",
      "content": "Replace $x$ with $2$ in $$f(x) = 4(x - 2) + 8.$$ This gives $$f(2) = 4(2 - 2) + 8.$$"
    },
    {
      "title": "Compute the result",
      "content": "Simplify: $$f(2) = 4(0) + 8 = 0 + 8 = 8.$$ The answer is <strong>8</strong>."
    }
  ]
}
