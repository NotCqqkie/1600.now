  "steps": [
    {
      "title": "Substitute x equals 2 into the function",
      "content": "Given $f(x) = 4(x - 2) + 8$, substitute $x = 2$:<br/>\n$$f(2) = 4(2 - 2) + 8$$"
    },
    {
      "title": "Simplify the expression",
      "content": "Evaluate the parentheses: $2 - 2 = 0$<br/>\n$$f(2) = 4(0) + 8 = 0 + 8 = 8$$"
    }
  ]
}