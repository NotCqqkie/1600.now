    {
      "title": "Isolate the variable term",
      "content": "Subtract 5 from both sides:<br/>$$4x + 5 - 5 = 165 - 5$$<br/>$$4x = 160$$"
    },
    {
      "title": "Divide to solve for x",
      "content": "Divide both sides by 4:<br/>$$\\frac{4x}{4} = \\frac{160}{4}$$<br/>$$x = 40$$"
    }
  ]
}