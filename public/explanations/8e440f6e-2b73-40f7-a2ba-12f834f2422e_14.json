  "steps": [
    {
      "title": "Find the x-intercept",
      "content": "Set $y = 0$ in $-8x + 3.6y = -720$:<br/>$$-8x = -720$$<br/>$$x = 90$$<br/>So $a = 90$."
    },
    {
      "title": "Find the y-intercept",
      "content": "Set $x = 0$ in $-8x + 3.6y = -720$:<br/>$$3.6y = -720$$<br/>$$y = \\frac{-720}{3.6} = -200$$<br/>So $b = -200$."
    },
    {
      "title": "Calculate the product",
      "content": "$$ab = 90 \\times (-200) = -18000$$"
    }
  ]
}