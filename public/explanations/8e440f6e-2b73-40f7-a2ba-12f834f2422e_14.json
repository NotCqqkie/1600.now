  "steps": [
    {
      "title": "Find the x-intercept",
      "content": "Set $y = 0$ in $-6x + 4.4y = -660$:<br/>$$-6x = -660$$<br/>$$x = 110$$<br/>So $a = 110$."
    },
    {
      "title": "Find the y-intercept",
      "content": "Set $x = 0$ in $-6x + 4.4y = -660$:<br/>$$4.4y = -660$$<br/>$$y = \\frac{-660}{4.4} = -150$$<br/>So $b = -150$."
    },
    {
      "title": "Calculate the product",
      "content": "$$ab = 110 \\times (-150) = -16500$$"
    }
  ]
}