  "steps": [
    {
      "title": "Add the two functions",
      "content": "Use $h(x)=f(x)+g(x)$:<br/>$$h(x)=(\\frac{1}{5}x-8)+(\\frac{4}{5}x+18)$$"
    },
    {
      "title": "Simplify the function",
      "content": "Combine like terms:<br/>$$h(x)=\\frac{5}{5}x+10=x+10$$"
    },
    {
      "title": "Find the x-intercept",
      "content": "At the $x$-intercept, $h(x)=0$:<br/>$$x+10=0$$<br/>$$x=-10$$<br/>The answer is <strong>-10</strong>."
    }
  ]
}
