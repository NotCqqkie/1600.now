  "steps": [
    {
      "title": "Write vertex form",
      "content": "The maximum height is at $t=9$, so the vertex is $(9,2{,}025)$. Use vertex form:<br/>$$h(t)=a(t-9)^2+2{,}025$$",
      "formula": "$$y = a(x - h)^2 + k$$"
    },
    {
      "title": "Use the launch height",
      "content": "The launch height is $0$, so $h(0)=0$:<br/>$$0=a(0-9)^2+2{,}025$$<br/>$$0=81a+2{,}025$$<br/>$$a=-25$$"
    },
    {
      "title": "Evaluate at six seconds",
      "content": "Substitute $t=6$:<br/>$$h(6)=-25(6-9)^2+2{,}025$$<br/>$$h(6)=-25(9)+2{,}025=1{,}800$$<br/>The answer is <strong>1800</strong>."
    }
  ]
}
