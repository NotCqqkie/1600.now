  "steps": [
    {
      "title": "Set up",
      "content": "Find $g(-10)$ first: $g(x) = |12x - 7|$, so $g(-10) = |12(-10) - 7| = |-127| = 127$."
    },
    {
      "title": "Solve",
      "content": "$$f(-10) = 5(g(-10)) - 3 = 5(127) - 3 = 635 - 3 = 632$$"
    },
    {
      "title": "Answer",
      "content": "<strong>C</strong> is correct."
    }
  ]
}
