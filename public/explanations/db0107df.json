  "steps": [
    {
      "title": "Substitute for the intercept",
      "content": "At the $y$-intercept, $x=0$. Substitute $0$ into the equation:<br/>$$10(0)+3y=24$$<br/>$$3y=24$$"
    },
    {
      "title": "Solve for the coordinate",
      "content": "Divide both sides by $3$:<br/>$$y=\\frac{24}{3}$$<br/>The answer is <strong>8</strong>."
    }
  ]
}
