  "section": "Math",
  "steps": [
    {
      "title": "Set up",
      "content": "Let u = 14 &minus; 4x. The equation becomes &minus;6u + 5 = &minus;7u + 22."
    },
    {
      "title": "Solve",
      "content": "Add 7u to both sides: u + 5 = 22 $\\Rightarrow$ u = 17. So 14 &minus; 4x = 17."
    },
    {
      "title": "Answer",
      "content": "<strong>17</strong> is correct."
    }
  ]
}