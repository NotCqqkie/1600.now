  "correctAnswer": "5.5",
  "section": "Math",
  "steps": [
    {
      "title": "Use the slope formula",
      "content": "For points $(4,5)$ and $(6,16)$, use the change in $y$ divided by the change in $x$.",
      "formula": "$$m = \\frac{y_2 - y_1}{x_2 - x_1}$$"
    },
    {
      "title": "Substitute the coordinates",
      "content": "$$m=\\frac{16-5}{6-4}=\\frac{11}{2}=5.5$$<br/>The answer is <strong>5.5</strong>."
    }
  ]
}
